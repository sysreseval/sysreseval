msgstr "flavor comme JSON dict (utilisé directement par sysreseval)"

msgid ""
"use a named Flavor preset defined as a class variable on the Flavor class "
"(privileged only)"
msgstr ""
"utiliser un préréglage Flavor nommé défini comme variable de classe sur la "
"classe Flavor (privilégiés uniquement)"

msgid "shell to launch instead of the machine default (privileged only)"
msgstr ""
"shell à lancer à la place du shell par défaut de la machine (privilégiés "
"uniquement)"

msgid "show files saved in archive"
msgstr "afficher les fichiers sauvegardés dans l'archive"

msgid "extract files saved in archive to current directory"
msgstr ""
"extraire les fichiers sauvegardés dans l'archive vers le répertoire courant"

msgid "recurse into subdirectories when searching for .zst archives"
msgstr ""
"parcourir récursivement les sous-répertoires lors de la recherche "
"d'archives .zst"

msgid "omit the evaluation history table from PDF reports"
msgstr "omettre le tableau d'historique des évaluations dans les rapports PDF"

msgid "include the time remaining column in the evaluation history table"
msgstr ""
"inclure la colonne du temps restant dans le tableau d'historique des "
"évaluations"

msgid "do not group PDF grade rows by GradePart (flat list, no subtotals)"
msgstr ""
"ne pas regrouper les lignes de notes du PDF par GradePart (liste à plat, "
"sans sous-totaux)"

msgid "Total for {part}"
msgstr "Total pour {part}"

msgid ""
"user list file with columns: LOGIN NAME EMAIL (adds Name/Email to PDFs and "
"ODS)"
msgstr ""
"fichier de liste d'utilisateurs avec les colonnes : LOGIN NOM EMAIL (ajoute "
"Nom/Email aux PDFs et ODS)"

msgid "lab names, optionally with a flavor preset (e.g. lab1:v1 lab2)"
msgstr ""
"nom des projets sre, avec éventuellement un nom de saveur (ie lab1:version1 "
"lab2"

msgid "Pre-pull Docker images referenced by lab files"
msgstr ""
"Pré-charge les images Docker référencées dans les fichiers des projets sre"

msgid "wait a random delay of 0 to N seconds before pulling"
msgstr ""
"attendre un délai aléatoire de 0 à N secondes avant de télécharger les images"

msgid "lab .py file(s) or director(ies) to scan recursively"
msgstr "fichiers projets sre (.py) ou répertoires à parcourir récursivement"

msgid "--user and --debug are mutually exclusive"
msgstr "--user et --debug sont incompatibles"

msgid "illegal userid"
msgstr "numéro d'utilisateur (userid) illégal"

msgid "execute a command via the shell and return (privileged only)"
msgstr ""
"exécuter une commande via le shell et terminer (privilégiés uniquement)"

msgid "Execute a command in a device (privileged only)"
msgstr "Exécuter une commande dans un équipement (privilégiés uniquement)"

msgid "shell to use instead of the default"
msgstr "shell à utiliser à la place du shell par défaut"

msgid "command to execute"
msgstr "commande à exécuter"

msgid "lab names, optionally with a flavor preset (e.g. lab1:hard lab2)"
msgstr ""
"noms des labs, avec éventuellement un préréglage flavor (ex. lab1:hard lab2)"

msgid "Compare re-graded results with stored grades in archives"
msgstr ""
"Comparer les résultats recorrigés avec les notes stockées dans les archives"

msgid "path to srelab.py or directory (default: taken from archive)"
msgstr "chemin vers srelab.py ou un répertoire (défaut : pris dans l'archive)"

msgid "archive file(s) to check"
msgstr "archive(s) à vérifier"

msgid "must be launched via sre-wrapper"
msgstr "doit être lancé via sre-wrapper"

msgid "archive file(s) or director(ies) of .zst archives to re-evaluate"
msgstr "archive(s) ou répertoire(s) d'archives .zst à recorriger"

msgid "execute a command via the shell and return"
msgstr "exécuter une commande via le shell et terminer"

msgid "path to the lab file or directory"
msgstr "chemin vers le fichier de lab ou son répertoire"

#, python-brace-format
msgid "invalid username: '{}'"
msgstr "nom d'utilisateur invalide : '{}'"

msgid "Dual commands, used both by sysreseval for administration:"
msgstr "Commandes mixtes, utilisées par sysreseval et pour l'administration :"

msgid "Admin-only commands:"
msgstr "Commandes d'administration uniquement :"

msgid "Admin-only commands for exam management:"
msgstr "Commandes d'administration pour la gestion des examens :"

msgid "Admin-only commands for post-exam management:"
msgstr "Commandes d'administration pour la gestion post-examen :"

msgid "Internal (only used by sysreseval GUI):"
msgstr "Internes (utilisées uniquement par sysreseval) :"

msgid "do not record the session (privileged only)"
msgstr "ne pas enregistrer la session (utilisateurs privilégiés uniquement)"

msgid ""
"user-triggered self-evaluation: enable cooldown, log timestamp, return result"
msgstr ""
"auto-évaluation déclenchée par l'utilisateur : active le délai de "
"réutilisation, enregistre l'horodatage, retourne le résultat"

msgid ""
"start the project in debug mode (privileged only): exposes all grade scopes, "
"lifts user-mode restrictions, surfaces every machine"
msgstr ""
"démarrer le projet en mode debug (privilégiés uniquement) : expose tous les "
"scopes de notes, lève les restrictions du mode utilisateur, affiche toutes "
"les machines"

msgid "Generate titles.json file(s) for a lab directory"
msgstr "Générer les fichiers titles.json pour un répertoire de labs"

msgid "directory to scan"
msgstr "répertoire à analyser"

msgid "write all titles to FILE instead of <directory>/titles.json"
msgstr ""
"écrire tous les titres dans FICHIER au lieu de <répertoire>/titles.json"

msgid "recursively scan subdirectories, writing one titles.json per directory"
msgstr ""
"analyser récursivement les sous-répertoires, en écrivant un titles.json par "
"répertoire"

msgid "output .ods summary file (omit to skip ODS generation)"
msgstr ""
"fichier .ods récapitulatif de sortie (omettre pour ignorer la génération de "
"ce fichier)"

msgid "output directory for PDF reports (omit to skip PDF generation)"
msgstr ""
"répertoire de sortie pour les rapports PDF (omettre pour ignorer la "
"génération des PDFs)"

msgid ""
"emit a list of {name, title} objects, reading translated titles from per-"
"directory titles.json"
msgstr ""
"émettre une liste d'objets {name, title}, en lisant les titres traduits "
"depuis les titles.json de chaque répertoire"

